{
  "groups": {
    "composerregistries": {
      "description": "PHP Composer package registry provider (e.g., packagist.org).",
      "plural": "composerregistries",
      "singular": "composerregistry",
      "resources": {
        "packages": {
          "description": "A Composer package in the registry, including its metadata and available versions.",
          "plural": "packages",
          "singular": "package",
          "hasdocument": false,
          "attributes": {
            "name": {
              "type": "string",
              "description": "The canonical vendor/package name of the Composer package."
            },
            "description": {
              "type": "string",
              "description": "A short description of the package."
            },
            "type": {
              "type": "string",
              "description": "The package type (e.g., library, project, symfony-bundle)."
            },
            "license": {
              "type": "array",
              "item": { "type": "string" },
              "description": "The license(s) under which the package is distributed."
            },
            "homepage": {
              "type": "string",
              "description": "The main homepage URL for the package."
            },
            "repository": {
              "type": "string",
              "description": "The VCS repository URL for the package."
            },
            "keywords": {
              "type": "array",
              "item": { "type": "string" },
              "description": "Keywords that describe the package."
            },
            "authors": {
              "type": "array",
              "item": {
                "type": "object",
                "attributes": {
                  "name": { "type": "string", "description": "Author name." },
                  "email": { "type": "string", "description": "Author email." },
                  "homepage": { "type": "string", "description": "Author homepage." },
                  "role": { "type": "string", "description": "Author role." }
                }
              },
              "description": "Package authors."
            },
            "downloads": {
              "type": "object",
              "description": "Download statistics (total, monthly, daily)."
            },
            "favers": {
              "type": "integer",
              "description": "Number of users who have starred/favorited the package."
            },
            "abandoned": {
              "type": "string",
              "description": "If set, the package name this package is replaced by; empty string means simply abandoned."
            },
            "suggest": {
              "type": "object",
              "description": "Suggested optional packages."
            }
          },
          "versions": {
            "description": "A specific version of the Composer package.",
            "plural": "versions",
            "singular": "version",
            "hasdocument": false,
            "attributes": {
              "version": {
                "type": "string",
                "description": "The normalized version string (e.g., 1.0.0, dev-main)."
              },
              "versionNormalized": {
                "type": "string",
                "description": "The Composer-normalized version string."
              },
              "type": {
                "type": "string",
                "description": "The package type for this version."
              },
              "license": {
                "type": "array",
                "item": { "type": "string" },
                "description": "License(s) for this version."
              },
              "require": {
                "type": "object",
                "description": "Runtime dependencies required by this version."
              },
              "requireDev": {
                "type": "object",
                "description": "Development-only dependencies."
              },
              "conflict": {
                "type": "object",
                "description": "Packages that conflict with this version."
              },
              "replace": {
                "type": "object",
                "description": "Packages replaced by this version."
              },
              "provide": {
                "type": "object",
                "description": "Virtual packages provided by this version."
              },
              "suggest": {
                "type": "object",
                "description": "Suggested optional packages."
              },
              "authors": {
                "type": "array",
                "item": { "type": "object" },
                "description": "Authors of this version."
              },
              "dist": {
                "type": "object",
                "description": "Distribution download information (URL, type, shasum, reference)."
              },
              "source": {
                "type": "object",
                "description": "Source VCS information (URL, type, reference/commit SHA)."
              },
              "sourceReference": {
                "type": "string",
                "description": "The VCS reference (commit SHA or branch) this version was built from. Critical for dev-* mutable aliases."
              },
              "immutable": {
                "type": "boolean",
                "description": "True for stable tagged releases; false for dev-* branch aliases which are mutable."
              },
              "autoload": {
                "type": "object",
                "description": "Autoload rules for this version."
              },
              "extra": {
                "type": "object",
                "description": "Arbitrary extra data for this version."
              },
              "time": {
                "type": "string",
                "description": "Release timestamp for this version in RFC3339 format."
              }
            }
          }
        }
      }
    }
  }
}
