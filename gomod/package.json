{
  "name": "xregistry-gomod-proxy",
  "version": "1.0.0",
  "description": "xRegistry proxy for the Go Module ecosystem, using the GOPROXY protocol for exact lookup and the Go index for discovery",
  "main": "dist/gomod/src/server.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/gomod/src/server.js",
    "start:dev": "ts-node src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prebuild": "npm run clean"
  },
  "dependencies": {
    "@xregistry/registry-core": "file:../shared/registry-core",
    "express": "^5.2.1",
    "uuid": "^9.0.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.57",
    "@types/uuid": "^9.0.7",
    "@types/yargs": "^17.0.35",
    "jest": "^29.7.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^../../../shared/(.*)$": "<rootDir>/../shared/$1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "xregistry",
    "go",
    "golang",
    "module",
    "proxy",
    "goproxy"
  ],
  "license": "MIT"
}
