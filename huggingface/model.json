      "resources": {
        "models": {
          "plural": "models",
          "singular": "model",
          "description": "A Hugging Face model whose resource ID is the repository basename within its owner group.",
          "hasdocument": false,
          "attributes": {
            "repoid": {
              "type": "string",
              "description": "Full Hugging Face repository ID (owner/name or name)."
            },
            "author": {
              "type": "string",
              "description": "Owner / organisation of the model."
            },
            "sha": {
              "type": "string",
              "description": "Current HEAD commit SHA (default branch tip)."
            },
            "repository": {
              "type": "string",
              "description": "Canonical owner/repository ID, or the bare ID for an unnamespaced repository."
            },
            "namespace": {
              "type": "string",
              "description": "Canonical owner namespace, or empty for an unnamespaced repository."
            },
            "message": {
              "type": "string",
              "description": "Commit title or message for a Version."
            }
          },
          "maxversions": 0,
          "setversionid": true,
          "setdefaultversionsticky": false,
          "versionmode": "manual",
          "singleversionroot": false,
          "metaattributes": {
            "private": {
              "type": "boolean",
              "description": "Whether the repository is private."
            },
            "gated": {
              "type": "any",
              "description": "Gated-access status as returned by the Hub (false, 'auto', or 'manual')."
            },
            "downloads": {
              "type": "integer",
              "description": "Total download count (anonymously visible)."
            },
            "likes": {
