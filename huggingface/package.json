{
  "name": "xregistry-huggingface-bridge",
  "version": "1.0.0",
  "description": "xRegistry proxy for Hugging Face Hub – anonymous, read-only (models, datasets, spaces)",
  "main": "dist/src/server.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "node dist/src/server.js",
    "start:dev": "ts-node src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@xregistry/registry-core": "file:../shared/registry-core",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.19.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "xregistry",
    "huggingface",
    "machine-learning",
    "models",
    "datasets",
    "spaces"
  ],
  "license": "MIT"
}
