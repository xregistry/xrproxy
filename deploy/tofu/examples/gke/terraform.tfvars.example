# GKE non-production example — copy to terraform.tfvars and fill in values.

cluster_name       = "xrproxy-dev"
environment        = "dev"
region             = "us-central1"
gcp_project_id     = "my-gcp-project"   # Replace with your GCP project ID
kubernetes_version = "1.31"

system_node_pool = {
  vm_size   = "e2-standard-4"
  min_count = 2
  max_count = 4
}

workload_node_pool = {
  vm_size   = "e2-standard-8"
  min_count = 1
  max_count = 4
}

network = {
  vpc_cidr           = "10.0.0.0/16"
  node_subnet_cidr   = "10.0.0.0/22"
  pod_cidr           = "10.244.0.0/16"
  service_cidr       = "10.96.0.0/16"
  dns_service_ip     = "10.96.0.10"
  availability_zones = []
}

oci_registry = {
  name = "xrproxy-dev"
}

workload_identity = {
  enabled    = true
  namespaces = ["default", "flux-system"]
}

static_egress = {
  enabled  = false
  ip_count = 1
}

dns = {
  enabled   = false
  zone_name = ""
}

certificates = {
  enabled        = true
  acme_email     = "platform@example.com"
  acme_server    = "https://acme-staging-v02.api.letsencrypt.org/directory"
  cluster_issuer = "letsencrypt-staging"
}

observability = {
  enabled   = true
  namespace = "monitoring"
}

flux = {
  enabled    = false
  git_url    = ""
  git_branch = "main"
  git_path   = "clusters/dev"
}

tags = {
  environment = "dev"
  team        = "platform"
}
