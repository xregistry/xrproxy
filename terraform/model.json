{
  "groups": {
    "terraformregistries": {
      "description": "A Terraform namespace on the configured registry host.",
      "plural": "terraformregistries",
      "singular": "terraformregistry",
      "resources": {
        "providers": {
          "description": "A Terraform provider. The resource ID is its provider type within the namespace group.",
          "plural": "providers",
          "singular": "provider",
          "hasdocument": false,
          "attributes": {
            "namespace": {
              "type": "string",
              "description": "The namespace (owner) of the provider on the Terraform Registry (e.g., hashicorp)."
            },
            "type": {
              "type": "string",
              "description": "The type identifier of the provider (e.g., aws)."
            },
            "source": {
              "type": "string",
              "description": "Canonical provider source address namespace/type."
            },
            "description": {
              "type": "string",
              "description": "Human-readable description of the provider."
            },
            "registryhost": {
              "type": "string",
              "description": "Upstream Terraform registry host."
            },
            "protocols": {
              "type": "array",
              "item": {
                "type": "string"
              },
              "description": "Supported Terraform plugin protocol versions."
            },
            "platforms": {
              "type": "array",
              "item": {
                "type": "object",
                "attributes": {
                  "os": {
                    "type": "string"
                  },
                  "arch": {
                    "type": "string"
                  },
                  "filename": {
                    "type": "string"
                  },
                  "download_url": {
                    "type": "string"
                  },
                  "shasums_url": {
                    "type": "string"
                  },
                  "shasums_signature_url": {
                    "type": "string"
                  },
                  "shasum": {
                    "type": "string"
                  }
                }
              },
              "description": "Supported platform summaries or enriched download distributions."
            },
            "signing_keys": {
              "type": "object",
              "attributes": {
                "gpg_public_keys": {
                  "type": "array",
                  "item": {
                    "type": "object",
                    "attributes": {
                      "key_id": {
                        "type": "string"
                      },
                      "ascii_armor": {
                        "type": "string"
                      },
                      "trust_signature": {
                        "type": "string"
                      },
                      "source": {
                        "type": "string"
                      },
                      "source_url": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "description": "Signing keys returned by provider download metadata."
            }
          },
          "maxversions": 0,
          "setversionid": true,
          "versionmode": "semver",
          "singleversionroot": true,
          "setdefaultversionsticky": false,
          "metaattributes": {
            "downloads": {
              "type": "integer",
              "description": "Total cumulative download count from the Terraform Registry."
            },
            "tier": {
              "type": "string",
              "description": "Provider tier: official, partner, or community."
            },
            "logo_url": {
              "type": "string",
              "description": "URL to the provider's logo image."
            },
            "categories": {
              "type": "array",
              "item": {
                "type": "string"
              },
              "description": "Categories that describe the provider's purpose."
            },
            "featured": {
              "type": "boolean",
              "description": "Whether the provider is featured on the Terraform Registry."
            },
            "unlisted": {
              "type": "boolean",
              "description": "Whether the provider is unlisted on the Terraform Registry."
            },
            "warning": {
              "type": "string",
              "description": "Optional deprecation or warning message from the registry."
            },
            "aliases": {
              "type": "array",
              "item": {
                "type": "string"
              },
              "description": "Alternate source addresses for this provider."
            }
          }
        },
        "modules": {
          "description": "A Terraform module. The resource ID is reversible name~provider within the namespace group.",
          "plural": "modules",
          "singular": "module",
          "hasdocument": false,
          "attributes": {
            "namespace": {
              "type": "string",
              "description": "The namespace (owner) of the module on the Terraform Registry."
            },
            "name": {
              "type": "string",
              "description": "The module name (e.g., consul)."
            },
            "provider": {
              "type": "string",
              "description": "The provider system this module targets (e.g., aws)."
            },
            "source": {
              "type": "string",
              "description": "Canonical module source address namespace/name/provider."
            },
            "description": {
              "type": "string",
              "description": "Human-readable description of the module."
            },
            "downloads": {
              "type": "integer",
              "description": "Total cumulative download count from the Terraform Registry."
            },
            "verified": {
              "type": "boolean",
              "description": "Whether the module is verified by HashiCorp."
            },
            "owner": {
              "type": "string",
              "description": "GitHub username or organisation that owns the module repository."
            },
            "registryhost": {
              "type": "string",
              "description": "Upstream Terraform registry host."
            },
            "published_at": {
              "type": "timestamp",
              "description": "UTC timestamp when this module Version was published."
            }
          },
          "maxversions": 0,
          "setversionid": true,
          "versionmode": "semver",
          "singleversionroot": true,
          "setdefaultversionsticky": false,
          "metaattributes": {
            "trusted": {
              "type": "boolean",
              "description": "Whether the module publisher is trusted."
            }
          }
        }
      },
      "attributes": {
        "namespace": {
          "type": "string",
          "description": "Canonical Terraform namespace and xRegistry group ID."
        },
        "registryhost": {
          "type": "string",
          "description": "Upstream Terraform registry host (registry.terraform.io for this proxy)."
        }
      }
    }
  }
}
