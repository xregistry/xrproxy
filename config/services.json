{
  "schemaVersion": 1,
  "services": [
    {
      "id": "npm",
      "name": "npm Registry",
      "role": "proxy",
      "status": "active",
      "directory": "npm",
      "port": 3100,
      "groupTypes": ["noderegistries"],
      "environment": {
        "PORT": "3100",
        "HOST": "0.0.0.0"
      },
      "images": [
        {
          "id": "npm",
          "name": "xregistry-npm-bridge",
          "dockerfile": "npm.Dockerfile"
        }
      ],
      "integrationTest": "test/integration/npm-docker.test.js",
      "deployment": {
        "replicas": 1,
        "healthPath": "/health",
        "readinessPath": "/health",
        "cpu": "500m",
        "memory": "1Gi"
      }
    },
    {
      "id": "pypi",
