{
  "specversion": "1.0-rc2",
  "registryid": "rubygems-wrapper",
  "description": "The xRegistry model for the RubyGems wrapper, describing the structure and metadata for Ruby gem registries and packages.",
  "groups": {
    "rubyregistries": {
      "description": "A group representing a Ruby gem registry provider (e.g., rubygems.org).",
      "plural": "rubyregistries",
      "singular": "rubyregistry",
      "resources": {
        "packages": {
          "description": "A Ruby gem in the registry, including its metadata and available versions.",
          "plural": "packages",
          "singular": "package",
          "hasdocument": false,
          "attributes": {
            "name": {
              "type": "string",
              "description": "The canonical name of the Ruby gem."
            },
            "info": {
              "type": "string",
              "description": "Short description of the gem."
            },
            "version": {
              "type": "string",
              "description": "Latest stable version string."
            },
            "authors": {
              "type": "string",
              "description": "Comma-separated list of authors."
            },
            "licenses": {
              "type": "array",
              "item": {
                "type": "string"
              },
              "description": "SPDX license identifiers."
            },
            "gem_uri": {
              "type": "string",
              "description": "Direct download URL for the latest gem."
            },
            "version_downloads": {
              "type": "integer",
              "description": "Download count for the latest version."
            },
            "platform": {
              "type": "string",
              "description": "Build platform of the latest version."
            },
            "sha": {
              "type": "string",
              "description": "SHA-256 checksum of the latest gem file."
            },
            "dependencies": {
              "type": "object",
              "attributes": {
                "development": {
                  "type": "array",
                  "item": {
                    "type": "object",
                    "attributes": {
                      "name": {
                        "type": "string"
                      },
                      "requirements": {
                        "type": "string"
                      }
                    }
                  }
                },
                "runtime": {
                  "type": "array",
                  "item": {
                    "type": "object",
                    "attributes": {
                      "name": {
                        "type": "string"
                      },
                      "requirements": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "description": "Runtime and development dependencies keyed by type."
            },
            "number": {
              "type": "string",
              "description": "Raw version string as published to RubyGems."
            },
            "prerelease": {
              "type": "boolean",
              "description": "True if this is a pre-release version."
            },
            "created_at": {
              "type": "timestamp",
              "description": "ISO 8601 timestamp when this version was published."
            },
            "downloads_count": {
              "type": "integer",
              "description": "Download count for this specific version+platform."
            },
            "yanked": {
              "type": "boolean",
              "description": "True if this version has been yanked from RubyGems."
            }
          },
          "maxversions": 0,
          "setversionid": true,
          "versionmode": "createdat",
          "singleversionroot": true,
          "metaattributes": {
            "homepage_uri": {
              "type": "string",
              "description": "Homepage URL."
            },
            "source_code_uri": {
              "type": "string",
              "description": "Source code repository URL."
            },
            "changelog_uri": {
              "type": "string",
              "description": "Changelog URL."
            },
            "documentation_uri": {
              "type": "string",
              "description": "Documentation URL."
            },
            "bug_tracker_uri": {
              "type": "string",
              "description": "Bug tracker URL."
            },
            "project_uri": {
              "type": "string",
              "description": "RubyGems project page URL."
            },
            "downloads": {
              "type": "integer",
              "description": "Total download count across all versions."
            }
          },
          "setdefaultversionsticky": false
        }
      }
    }
  }
}
